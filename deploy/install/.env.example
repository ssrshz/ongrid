# ==============================================================================
# ongrid production env - copy to .env and edit before first install
# Secrets without defaults MUST be set (install.sh will auto-generate if blank).
# ==============================================================================

ONGRID_VERSION=v0.7.113

# --- Host data root (v0.7.45+) ---
# All stateful services bind-mount to <ONGRID_DATA_DIR>/<service> instead of
# docker named volumes. Defaults to /var/lib/ongrid. Override to point at a
# dedicated SSD / NFS / iSCSI mount. install.sh / upgrade.sh mkdir + chown.
ONGRID_DATA_DIR=/var/lib/ongrid
ONGRID_LOG_DIR=/var/log/ongrid

# --- Ports exposed on the host (change if they collide with other services) ---
# ONGRID_HTTP_PORT is the host port for HTTPS (nginx, ADR-008). Defaults to
# 443; lower it to e.g. 8443 if 443 is already taken on the host.
# ONGRID_HTTP_REDIRECT_PORT is the host port for the 80 -> 443 redirect.
# Set to 0 to disable the redirect entirely (operators behind their own LB).
ONGRID_HTTP_PORT=443
ONGRID_HTTP_REDIRECT_PORT=80
ONGRID_TUNNEL_PORT=40012
ONGRID_METRICS_PORT=9100
PROM_PORT=9090

# --- MySQL (set passwords; install.sh generates random if left blank) ---
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# --- Grafana admin (install.sh generates random if left blank) ---
# Manager uses these creds at first boot to create a Service Account +
# token in the embedded Grafana, so admins don't have to do it manually.
# After bootstrap, the token lives in system_settings.grafana.sa_token
# and admin can rotate via UI.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# --- JWT signing (install.sh generates a random 64-char secret if blank) ---
ONGRID_JWT_SECRET=
ONGRID_JWT_ACCESS_TTL=15m
ONGRID_JWT_REFRESH_TTL=720h

# --- Bootstrap admin (created on first start if users table is empty) ---
# Leave ONGRID_ADMIN_PASSWORD blank to let install.sh generate a random
# 20-char password; it is printed once at the end of installation.
ONGRID_ADMIN_EMAIL=admin@ongrid.local
ONGRID_ADMIN_PASSWORD=

# --- Public URL the manager hands to edges as the data-plane endpoint
# for plugin telemetry (logs / traces). install.sh auto-fills with the
# operator's host + HTTPS port if blank. Edit if you put a real domain
# / load balancer in front: e.g. https://ops.example.com
ONGRID_PUBLIC_URL=

# --- OpenAI (leave blank to run without AI chat) ---
# OPENAI_MODEL: leave blank to take the Go-side current default (gpt-5.4).
# Hard-coding a value here pins the seed list to it across upgrades — that's
# how gpt-4o leaked back into fresh installs after the v0.7.155/156 default
# refresh. Set only if you really want to override the in-code default.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# --- Auto root-cause analysis (HLD-011) ---
# true: every incident at/above MIN_SEVERITY spawns a structured-report RCA
# worker (the 根因分析 panel on the incident page), using the default chat
# provider. Set false to suppress the per-incident LLM spend. The summarizer
# auto-picks the default provider's model — no extra model config needed.
ONGRID_INVESTIGATOR_ENABLED=true
ONGRID_INVESTIGATOR_MIN_SEVERITY=warning

# --- Embedding provider for RAG / 知识库 ---
# Two choices:
#
#   local (default) — bundled BGE-small-zh-v1.5 ONNX (中英混合, dim=512).
#     No API key, no network: 知识库 works out of the box, including
#     air-gapped installs. The model ships in the tarball and install.sh
#     stages it under /var/lib/ongrid/embeddings/ automatically. This is
#     the default so a fresh install can sync the built-in vault and run
#     semantic search with zero extra config.
#
#   openai — any OpenAI-compatible /v1/embeddings endpoint (OpenAI, GLM,
#     Qwen, DeepSeek). Higher quality / bigger dim, but needs a key + net.
#     To switch:
#       ONGRID_EMBEDDING_PROVIDER=openai
#       ONGRID_EMBEDDING_API_KEY=<vendor key>
#       ONGRID_EMBEDDING_BASE_URL=<vendor /v1 base>
#       ONGRID_EMBEDDING_MODEL=text-embedding-3-small
#       ONGRID_EMBEDDING_DIM=1536        # match the vendor's model
#
# NB: ONGRID_EMBEDDING_DIM must match the active provider's output dim, or
# qdrant rejects upserts. Changing provider/dim on a populated collection
# requires a re-index (qdrantx auto drop+recreate kicks in only when empty).
# NB: MODEL must be a non-empty local model name here, NOT blank. The
# compose file resolves it as ${ONGRID_EMBEDDING_MODEL:-text-embedding-3-small},
# and `:-` substitutes the default on EMPTY too — so a blank value would
# wrongly feed the local embedder an OpenAI model name and fail to load.
ONGRID_EMBEDDING_PROVIDER=local
ONGRID_EMBEDDING_API_KEY=
ONGRID_EMBEDDING_MODEL=bge-small-zh-v1.5
ONGRID_EMBEDDING_BASE_URL=
ONGRID_EMBEDDING_DIM=512

# --- Advanced (usually leave alone) ---
ONGRID_HTTP_ADDR=:8080
ONGRID_METRICS_ADDR=:9100

# --- Frontier broker (upstream singchia/frontier; ADR-007) ---
# Manager dials the broker's service-bound port over the docker compose
# network. Container-internal only; never published to host. The broker's
# edge-bound port (40012) is mapped to host ${ONGRID_TUNNEL_PORT}; edges
# still see the same public endpoint.
ONGRID_FRONTIER_ADDR=frontier:40011
ONGRID_FRONTIER_SERVICE_NAME=ongrid-manager

# --- Cloud-side Prometheus (ADR-009) ---
# Compose deploys a Prometheus container; flip ONGRID_PROM_ENABLED=true so
# the manager forwards edge-pushed open-set samples to remote_write and
# exposes the query_promql AI tool. Leave URL pointing at the in-network
# prometheus container on its standard port.
ONGRID_PROM_ENABLED=true
ONGRID_PROM_URL=http://prometheus:9090/prometheus
# Optional exact remote_write endpoint for Prometheus-compatible TSDBs
# (VictoriaMetrics / Mimir / Cortex / Thanos receive). Empty means
# ONGRID_PROM_URL + /api/v1/write.
ONGRID_PROM_REMOTE_WRITE_URL=
# Optional Prometheus-compatible query API root. Empty means ONGRID_PROM_URL.
ONGRID_PROM_QUERY_URL=http://prometheus:9090/prometheus
# TLS for the TSDB. Insecure skips cert verification (NOT for prod). CA file
# path takes precedence when both are set.
ONGRID_PROM_TLS_INSECURE=false
ONGRID_PROM_TLS_CA_FILE=
# Auth (Bearer / Basic) is NOT set via env — admin configures it in the
# UI under Settings → 集成. The values land in system_settings and the
# manager refreshes them every ~5s without restart. Env URL/TLS values
# above are only first-boot seeds.
ONGRID_GRAFANA_ROOT_URL=%(protocol)s://%(domain)s/grafana/
# Internal URL the manager uses to call Grafana via the docker network.
# Out of the box the embedded Grafana lives at http://grafana:3000/grafana
# (with the /grafana sub-path from GF_SERVER_SERVE_FROM_SUB_PATH=true).
# Admin can override in the UI to point at an external Grafana.
ONGRID_GRAFANA_INTERNAL_URL=http://grafana:3000/grafana

# --- Built-in host alert thresholds (fast-path HostMetricPoint) ---
ONGRID_ALERT_ENABLED=true
ONGRID_ALERT_COOLDOWN=10m
ONGRID_ALERT_CPU_PERCENT=90
ONGRID_ALERT_MEM_PERCENT=90
ONGRID_ALERT_DISK_USED_PERCENT=90
# 0 disables load1 alerting; set an absolute load threshold if desired.
ONGRID_ALERT_LOAD1=0

# --- Outbound notifications (alerts / scheduled jobs / proactive AIOps) ---
# Enabled by default — any channel you configure (in the UI or below) delivers.
# Set to false to mute all notifications.
ONGRID_NOTIFY_ENABLED=true
ONGRID_NOTIFY_DEFAULT_CHANNELS=
ONGRID_NOTIFY_TIMEOUT=10s

# Local dry-run sink. Useful before wiring real external channels.
ONGRID_NOTIFY_LOG_ENABLED=true
ONGRID_NOTIFY_LOG_NAME=log

# Generic JSON webhook. If secret is set, requests carry X-Ongrid-Signature.
ONGRID_NOTIFY_WEBHOOK_ENABLED=false
ONGRID_NOTIFY_WEBHOOK_NAME=webhook
ONGRID_NOTIFY_WEBHOOK_URL=
ONGRID_NOTIFY_WEBHOOK_SECRET=

# Slack incoming webhook.
ONGRID_NOTIFY_SLACK_ENABLED=false
ONGRID_NOTIFY_SLACK_NAME=slack
ONGRID_NOTIFY_SLACK_WEBHOOK_URL=

# Feishu/Lark custom bot webhook.
ONGRID_NOTIFY_FEISHU_ENABLED=false
ONGRID_NOTIFY_FEISHU_NAME=feishu
ONGRID_NOTIFY_FEISHU_WEBHOOK_URL=
ONGRID_NOTIFY_FEISHU_SECRET=

# DingTalk custom robot webhook.
ONGRID_NOTIFY_DINGTALK_ENABLED=false
ONGRID_NOTIFY_DINGTALK_NAME=dingtalk
ONGRID_NOTIFY_DINGTALK_WEBHOOK_URL=
ONGRID_NOTIFY_DINGTALK_SECRET=
